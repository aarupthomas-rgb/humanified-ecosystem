{
  "version": 2,
  "buildCommand": "true",
  "outputDirectory": "..",
  "public": true,
  "routes": [
    {
      "src": "^/(.*)$",
      "dest": "/$1",
      "status": 200
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
