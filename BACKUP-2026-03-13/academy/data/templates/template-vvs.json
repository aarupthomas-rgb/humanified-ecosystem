  "files": {
    "html": "<!DOCTYPE html>\n<html lang=\"da\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>VVS Service - Ekspert Rørlægning</title>\n</head>\n<body>\n  <header style=\"background: linear-gradient(135deg, #06b6d4 0%, #0891b2 100%); color: white; padding: 2rem; text-align: center;\">\n    <h1 style=\"margin: 0; font-size: 2.5rem;\">VVS Service</h1>\n    <p style=\"margin: 0.5rem 0 0; opacity: 0.9;\">Hurtig og pålidelig service</p>\n  </header>\n\n  <nav style=\"background: #0891b2; padding: 1rem; text-align: center;\">\n    <a href=\"#hjem\" style=\"color: white; text-decoration: none; margin: 0 1.5rem; font-weight: bold;\">Hjem</a>\n    <a href=\"#services\" style=\"color: white; text-decoration: none; margin: 0 1.5rem; font-weight: bold;\">Services</a>\n    <a href=\"#pris\" style=\"color: white; text-decoration: none; margin: 0 1.5rem; font-weight: bold;\">Priskalkulator</a>\n    <a href=\"#kontakt\" style=\"color: white; text-decoration: none; margin: 0 1.5rem; font-weight: bold;\">Ring Os</a>\n  </nav>\n\n  <main style=\"max-width: 1000px; margin: 0 auto; padding: 2rem;\">\n    <section id=\"hjem\">\n      <h2 style=\"color: #0891b2; border-bottom: 3px solid #06b6d4; padding-bottom: 1rem;\">Velkommen til VVS Service</h2>\n      <p style=\"line-height: 1.6; font-size: 1.1rem;\">Vi tilbyder komplet VVS-service til både private og kommercielle kunder. 24/7 nødservice tilgængelig.</p>\n    </section>\n\n    <section id=\"services\" style=\"margin-top: 3rem;\">\n      <h2 style=\"color: #0891b2; border-bottom: 3px solid #06b6d4; padding-bottom: 1rem;\">Vores Services</h2>\n      <div style=\"display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-top: 1.5rem;\">\n        <div style=\"background: #e0f7fa; padding: 1.5rem; border-radius: 8px; border-left: 4px solid #06b6d4;\">\n          <h3 style=\"color: #0891b2; margin-top: 0;\">Rørlægning</h3>\n          <p>Installation, reparation og vedligehold af røranlæg.</p>\n        </div>\n        <div style=\"background: #e0f7fa; padding: 1.5rem; border-radius: 8px; border-left: 4px solid #06b6d4;\">\n          <h3 style=\"color: #0891b2; margin-top: 0;\">Varme & Vand</h3>\n          <p>Installation af varmesystemer og vandinstallationer.</p>\n        </div>\n        <div style=\"background: #e0f7fa; padding: 1.5rem; border-radius: 8px; border-left: 4px solid #06b6d4;\">\n          <h3 style=\"color: #0891b2; margin-top: 0;\">Nødservice</h3>\n          <p>24/7 nødservice til akutte VVS-problemer.</p>\n        </div>\n        <div style=\"background: #e0f7fa; padding: 1.5rem; border-radius: 8px; border-left: 4px solid #06b6d4;\">\n          <h3 style=\"color: #0891b2; margin-top: 0;\">Vedligehold</h3>\n          <p>Regelmæssigt vedligehold af alle installationer.</p>\n        </div>\n      </div>\n    </section>\n\n    <section id=\"pris\" style=\"margin-top: 3rem; background: #e0f7fa; padding: 2rem; border-radius: 8px;\">\n      <h2 style=\"color: #0891b2; margin-top: 0;\">Priskalkulator</h2>\n      <form style=\"display: flex; flex-direction: column; gap: 1rem; max-width: 400px;\">\n        <label style=\"color: #0891b2; font-weight: bold;\">Vælg service type:</label>\n        <select style=\"padding: 0.75rem; border: 1px solid #06b6d4; border-radius: 4px;\" id=\"service\">\n          <option value=\"300\">Rørlægning - 300 kr</option>\n          <option value=\"400\">Varme system - 400 kr</option>\n          <option value=\"250\">Nødservice - 250 kr (pris + arbejde)</option>\n          <option value=\"150\">Vedligehold - 150 kr</option>\n        </select>\n        <label style=\"color: #0891b2; font-weight: bold;\">Antal timer:</label>\n        <input type=\"number\" id=\"timer\" value=\"2\" min=\"1\" style=\"padding: 0.75rem; border: 1px solid #06b6d4; border-radius: 4px;\">\n        <p style=\"color: #0891b2; font-weight: bold; font-size: 1.2rem;\">Estimeret pris: <span id=\"total\">600 kr</span></p>\n      </form>\n    </section>\n\n    <section id=\"kontakt\" style=\"margin-top: 3rem;\">\n      <h2 style=\"color: #0891b2; border-bottom: 3px solid #06b6d4; padding-bottom: 1rem;\">Kontakt Os</h2>\n      <p><strong>Telefon:</strong> <a href=\"tel:+4540123456\" style=\"color: #06b6d4;\">+45 40 12 34 56</a></p>\n      <p><strong>Email:</strong> <a href=\"mailto:info@vvsservice.dk\" style=\"color: #06b6d4;\">info@vvsservice.dk</a></p>\n      <p><strong>Åbningstider:</strong> Mandag-Fredag 7:00-18:00, Lørdag 8:00-14:00</p>\n      <p style=\"color: #999; margin-top: 1rem;\">Nødservice 24/7 tilgængelig</p>\n    </section>\n  </main>\n\n  <footer style=\"background: #0891b2; color: white; text-align: center; padding: 2rem; margin-top: 3rem;\">\n    <p style=\"margin: 0;\">© 2026 VVS Service. Alle rettigheder forbeholdt.</p>\n  </footer>\n</body>\n</html>",
    "css": "* {\n  margin: 0;\n  padding: 0;\n  box-sizing: border-box;\n}\n\nbody {\n  font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n  line-height: 1.6;\n  color: #333;\n}\n\nheader {\n  box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);\n}\n\na {\n  text-decoration: none;\n  transition: opacity 0.3s ease;\n}\n\na:hover {\n  opacity: 0.8;\n}",
    "js": "const serviceSelect = document.getElementById('service');\nconst timerInput = document.getElementById('timer');\nconst totalElement = document.getElementById('total');\n\nfunction updatePrice() {\n  const servicePrice = parseInt(serviceSelect.value);\n  const timer = parseInt(timerInput.value) || 1;\n  const total = servicePrice * timer;\n  totalElement.textContent = total + ' kr';\n}\n\nserviceSelect.addEventListener('change', updatePrice);\ntimerInput.addEventListener('change', updatePrice);\ntimerInput.addEventListener('input', updatePrice);"
  }
}
